# Frontend API base URL (no trailing slash)
VITE_API_URL=http://localhost:5001/api
# Enables Stripe Checkout on Place Order and "Prepay with card" on Order Status (requires API Stripe keys).
VITE_ENABLE_STRIPE_CHECKOUT=false
# Optional: VAPID public key for web push (admin/staff prompts); must match API Push__VapidPublicKey.
# VITE_VAPID_PUBLIC_KEY=
