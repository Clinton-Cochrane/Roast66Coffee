# Backend environment variables for Docker Compose (copy to CoffeeShopApi/.env)
# Used when running via docker-compose. Host=postgres-db is the Docker service name.
# NEVER use these defaults in production.

ConnectionStrings__DefaultConnection=Host=postgres-db;Port=5432;Database=coffeedb;Username=root;Password=toor
Admin__Username=admin
Admin__Password=CHANGE_ME
Jwt__Key=YourSuperSecretKeyAtLeast32CharactersLong
Jwt__Issuer=Roast66Coffee
Jwt__Audience=Roast66Coffee
Jwt__TokenExpiryInHours=1
AllowedOrigins=http://localhost:3000
KeepAlive__Enabled=false
KeepAlive__ProbeIntervalMinutes=4
KeepAlive__ActiveWindowMinutes=10
KeepAlive__SupabaseHeartbeatUrl=
KeepAlive__SupabaseServiceRoleKey=
Stripe__SecretKey=
Stripe__WebhookSecret=
Stripe__FrontendBaseUrl=http://localhost:3000
